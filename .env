# OpenAI API Key
# OPENAI_API_KEY=sk-proj-...
# Kimi (Moonshot AI) API Key
KIMI_API_KEY=

# Exa AI API Key (Search Engine for LLMs)
EXA_API_KEY=

# Database URL (Default matches docker-compose.yml)
DATABASE_URL=postgres://user:password@localhost:5432/shanzhai_db

# 代理设置 (本地开发建议开启，远端服务器请保持注释)
HTTPS_PROXY=http://host.docker.internal:6666
HTTP_PROXY=http://host.docker.internal:6666
